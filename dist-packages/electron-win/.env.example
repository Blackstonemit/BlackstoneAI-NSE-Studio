# ── NSE/BSE Trading Terminal — Windows Environment Variables ──────────────────
#
# Copy this file to .env and fill in your values before running.
# The app reads these automatically on startup.

# ── PostgreSQL (optional, for signals/watchlist persistence) ──────────────────
# Without this, the app runs in memory-only mode (data resets on restart).
DATABASE_URL=postgresql://username:password@localhost:5432/trading_db

# ── AI Provider: Option A — Direct OpenAI key ────────────────────────────────
OPENAI_API_KEY=sk-...

# ── AI Provider: Option B — NVIDIA NIM API (GPT-4o via NVIDIA) ───────────────
# NVIDIA_API_KEY=nvapi-...

# ── Replit AI Integration (if you have a Replit account) ─────────────────────
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://...
# AI_INTEGRATIONS_OPENAI_API_KEY=...
